<mujoco model="panda insert scene">
  <include file="panda_grasp.xml"/>

  <statistic center="0.45 0 0.35" extent="1.1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="cube_blue" rgba="0.1 0.35 1.0 1"/>
    <material name="socket_gray" rgba="0.35 0.38 0.42 1"/>
    <material name="socket_floor" rgba="0.05 0.07 0.08 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="cube" pos="0.48 0 0.02">
      <freejoint name="cube_freejoint"/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02" material="cube_blue"
        mass="0.04" friction="1.2 0.01 0.001" condim="4"/>
      <site name="cube_site" type="sphere" size="0.006" rgba="1 1 0 1"/>
    </body>

    <body name="socket_body" mocap="true" pos="0.55 0 0">
      <geom name="socket_floor_geom" type="box" pos="0 0 0.002" size="0.032 0.032 0.002"
        material="socket_floor" contype="1" conaffinity="1"/>
      <geom name="socket_wall_px" type="box" pos="0.044 0 0.025" size="0.012 0.044 0.025"
        material="socket_gray" friction="1.0 0.01 0.001"/>
      <geom name="socket_wall_nx" type="box" pos="-0.044 0 0.025" size="0.012 0.044 0.025"
        material="socket_gray" friction="1.0 0.01 0.001"/>
      <geom name="socket_wall_py" type="box" pos="0 0.044 0.025" size="0.044 0.012 0.025"
        material="socket_gray" friction="1.0 0.01 0.001"/>
      <geom name="socket_wall_ny" type="box" pos="0 -0.044 0.025" size="0.044 0.012 0.025"
        material="socket_gray" friction="1.0 0.01 0.001"/>
      <site name="insert_target_site" type="sphere" pos="0 0 0.02" size="0.006" rgba="0 1 0 0.55"/>
    </body>
  </worldbody>
</mujoco>
